# Copy this file to `.env` and fill in the values.

# Discord bot token. Required to run the bot.
# Create one at https://discord.com/developers/docs/getting-started#step-1-creating-an-app
BOT_TOKEN="<YOUR_BOT_TOKEN>"

# Database connection string (SQLAlchemy URL). The bot reads this from the
# DATABASE_URL env var; if unset it falls back to the local SQLite file
# (sqlite:///bumper-db.sqlite).
#
# Dev default — local Postgres via Docker (`docker compose up -d`):
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/bumper"
#
# Production — Supabase. Use the POOLED (PgBouncer / transaction-mode)
# connection string from your Supabase project settings:
# DATABASE_URL="postgresql+psycopg://USER:PASS@HOST:PORT/postgres"
